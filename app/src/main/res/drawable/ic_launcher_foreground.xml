    <path
        android:strokeColor="#5A3D14"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,33 L50,38 L58,43 L50,48 L58,53 L50,58 L58,63 L50,68 L54,72" />
