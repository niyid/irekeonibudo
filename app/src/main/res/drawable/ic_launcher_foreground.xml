    <path android:pathData="M32,52 C32,36 42,25 54,25 C66,25 76,36 76,52 C76,68 66,79 54,79 C42,79 32,68 32,52 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="32"
                android:startY="25"
                android:endX="76"
                android:endY="79"
                android:startColor="#F3D998"
                android:endColor="#C6892E" />
        </aapt:attr>
    </path>
    <!-- Rim highlight -->
    <path
        android:fillColor="#FCEFD1"
